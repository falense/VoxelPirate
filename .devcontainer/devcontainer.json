{
  "name": "Claude Code AI Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Europe/Oslo}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
      "USERNAME": "${localEnv:USER}",
      "WORKSPACE_DIR": "${localWorkspaceFolder}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--device=/dev/dri",
    // GPU device access: card* is group video (44), renderD* is the host's
    // render group (gid 110 on this machine — check ls -ln /dev/dri).
    "--group-add=video",
    "--group-add=110"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "${localEnv:USER}",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.claude,target=${localEnv:HOME}/.claude,type=bind",
    "source=craftpirate-cargo-registry,target=${localEnv:HOME}/.cargo/registry,type=volume",
    "source=craftpirate-target,target=${localWorkspaceFolder}/target,type=volume",
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "${localEnv:HOME}/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "DISPLAY": "${localEnv:DISPLAY::0}",
    "WINIT_UNIX_BACKEND": "x11"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=delegated",
  "workspaceFolder": "${localWorkspaceFolder}",
  "postCreateCommand": "sudo chown -R \"$(id -u):$(id -g)\" \"$HOME/.cargo/registry\" ./target && sudo /usr/local/bin/init-firewall.sh"
}
